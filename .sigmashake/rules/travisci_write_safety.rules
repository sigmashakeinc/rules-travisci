# travisci_write_safety.rules
# Technology: travisci | Capability: write

rule travisci-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "UNSAFE_travisci_PATTERN"
  MESSAGE "Blocked an unsafe pattern in travisci. Use the recommended best practices for 2025/2026."
}

rule travisci-force-updated-api {
  enabled true
  priority 80
  severity warning
  ASK write
  IF path GLOB "**/*" AND content CONTAINS "OLD_travisci_API"
  MESSAGE "You are using an outdated API for travisci. Please upgrade to the newer API."
}
